# Codex - sensitive and runtime data
.codex/
codex/config.local.toml
codex/*.local.toml
codex/**/*.local.toml


# Sensitive authentication files (global)
**/auth-profiles.json
**/*.credentials.json
**/oauth-tokens.json

# Nix
result
result-*

# macOS
.DS_Store

# no sleep marker
.no-sleep-server
