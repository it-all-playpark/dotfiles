# Claude Code - sensitive and runtime data
.claude/
.antigravitycli/
claude-code/.credentials.json
claude-code/history.jsonl
claude-code/cache/
claude-code/logs/
claude-code/file-history/
claude-code/debug/
claude-code/backups/
# claude-code/agents/ は dotfiles 管理対象（symlink 元）
