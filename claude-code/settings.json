        "proxy.golang.org",
        "sum.golang.org",
        "go.dev",
        "storage.googleapis.com",
        "zernio.com",
        "*.amazonaws.com",
        "*.googleapis.com",
        "accounts.google.com",
        "trends.google.com",
        "fonts.gstatic.com",
        "qiita.com",
        "zenn.dev",
        "api.slack.com"
      ]
    }
  },
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "tui": "fullscreen",
  "voiceEnabled": true,
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".cache"
    ]
  }
}
