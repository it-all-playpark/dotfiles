{
  "blog-fact-check": {
    "check_targets": [
      "statistics",
      "pricing",
      "versions",
      "dates"
    ],
    "output_dir": "claudedocs",
    "severity_threshold": "warning"
  },
  "blog-internal-links": {
    "max_links_per_article": 5,
    "min_links_per_article": 2,
    "output_dir": "claudedocs",
    "prevent_future_links": true
  },
  "blog-mv-date": {
    "content_dir": "content/blog",
    "image_dir": "public/blog",
    "image_ext": ".webp",
    "seed_dir": "seed",
    "sns_post_dir": "post/blog"
  },
  "blog-schedule-overview": {
    "lookahead_days": 30,
    "lookback_days": 7,
    "publish_days": [
      "monday",
      "thursday"
    ]
  },
  "blog-seo-improve": {
    "output_dir": "claudedocs",
    "thresholds": {
      "high_bounce": 0.75,
      "low_ctr": 0.02,
      "min_impressions": 50
    }
  },
  "blog-swap-dates": {
    "content_dir": "content/blog",
    "image_dir": "public/blog",
    "image_ext": ".webp",
    "seed_dir": "seed",
    "sns_post_dir": "post/blog"
  },
  "cross-post-publish": {
    "content_dir": "content/blog",
    "cross_post_categories": [
      "tech-tips",
      "lab-reports"
    ],
    "cross_post_dir": "post/cross-post"
  },
  "generate-thumbnail": {
    "aspect_ratio": "16:9",
    "brand_prompt_path": "",
    "gemini_model": "gemini-3-pro-image-preview",
    "output_dir": "public/blog"
  },
  "get-publish-date": {
    "content_dir": "content/blog",
    "publish_days": [
      "monday",
      "thursday"
    ]
  },
